# =============================================================================
# Polyglot .gitignore — R + Python + Stata
# Shared across project-template-r and project-template so users can
# mix languages freely regardless of which template they start from.
# =============================================================================


# === R ========================================================================

# Session and history
.Rhistory
.Rapp.history
.RData
.RDataTmp
.Ruserdata
.Renviron

# RStudio
.Rproj.user/
*.Rproj
rsconnect/

# Package build artifacts
*-Ex.R
/*.tar.gz
/*.Rcheck/

# Vignettes / R Markdown / knitr
vignettes/*.html
vignettes/*.pdf
*_cache/
/cache/
*.utf8.md
*.knit.md
/*_files/
/files/
/src/*_files/

# OAuth token
.httr-oauth

# pkgdown
docs/

# Translation temp files
po/*~


# === Python ===================================================================

# Virtual environments (uv, venv, virtualenv)
.venv/
venv/
ENV/

# Byte-compiled / cached
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Distribution / packaging
*.egg-info/
*.egg
dist/
build/

# Jupyter
.ipynb_checkpoints/

# mypy / type checkers
.mypy_cache/
.ruff_cache/


# === Stata ====================================================================

# Stata temp/log files
*.smcl
*.sthlp


# === Shared / project-level ==================================================

# Environment files (credentials, local paths — never commit)
.env

# Claude Code local settings
.claude/

# Output files (generated by scripts — keep directory via .gitkeep)
output/*
!output/.gitkeep
/out/*

# Common generated file types
*.html
*.pdf
*.aux
*.rda

# Log files from run-all.R
log/

# Data files (large, stored outside repo per .env DATA_DIR)
*.parquet
*.dta
*.sas7bdat
*.csv

# macOS
.DS_Store
